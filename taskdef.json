{
    "family": "myapplication-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "myapp-container",
            "image": "<IMAGE_NAME>",
            "portMappings": [
                {
                    "containerPort": 3000,
                    "hostPort": 3000,
                    "protocol": "tcp"
                }
            ],
            "essential": true
        }
    ],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
    "executionRoleArn": "arn:aws:iam::541426239397:role/ecsTaskExecutionRole"
}