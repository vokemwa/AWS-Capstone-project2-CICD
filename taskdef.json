{
  "family": "myapp-task",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "myapp-container",
      "image": "541426239397.dkr.ecr.us-east-1.amazonaws.com/myapp-repo:latest",
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true 				
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
			 
	
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::541426239397:role/ecsTaskExecutionRole"
}